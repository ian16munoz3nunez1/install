FROM kalilinux/kali-rolling:latest
SHELL ["/bin/bash", "-c"]

# Run
# ```
# sudo xhost +local:docker
# sudo xhost +local:root // Optional
# ```
# to enable docker to use the DISPLAY of the system
#
# Run
# ```
# docker build . -t kali -f kalidock --no-cache --network host
# ```
# to build a new image of kalilinux-rolling
#
# Run
# ```
# docker run --name kali --privileged --net host -it
# -e DISPLAY=$DISPLAY
# -v /tmp/.X11-unix:/tmp/.X11-unix:ro
# -v /etc/localtime:/etc/localtime:ro
# -d kali
# ```
# to run the kalilinux-rolling image
#
# Run
# ```
# docker run --name kali --privileged --net host -it
# -e DISPLAY=$DISPLAY
# -v /tmp/.X11-unix:/tmp/.X11-unix:ro
# -v /etc/localtime:/etc/localtime:ro
# --device /dev/dri
# --device /dev/snd
# -e PULSE_SERVER=unix:/run/user/1000/pulse/native
# -v /run/user/1000/pulse:/run/user/1000/pulse:ro
# -d kali
# ```

RUN apt-get update -y && apt-get upgrade -y
# RUN rm -rf /var/lib/apt/lists/*
RUN ln -sfn /usr/share/zoneinfo/America/Mexico_City /etc/localtime

RUN apt-get install dbus-x11 ca-certificates -y
RUN apt-get install ristretto mpv gwenview -y
RUN apt-get install libgl1 libglib2.0-0 -y
RUN apt-get install iputils-ping -y
RUN apt-get install net-tools -y
RUN apt-get install iproute2 -y
RUN apt-get install net-tools -y
RUN apt-get install tcpdump -y
RUN apt-get install wireless-tools -y
RUN apt-get install wpasupplicant -y
RUN apt-get install adb -y
RUN apt-get install ssh -y
RUN apt-get install powershell -y
RUN apt-get install rsync -y
RUN apt-get install ftp -y
RUN apt-get install nmap -y
RUN apt-get install hydra -y
RUN apt-get install medusa -y
RUN apt-get install metasploit-framework -y
RUN apt-get install ncat -y
RUN apt-get install git -y
RUN apt-get install bat -y
RUN apt-get install htop -y
RUN apt-get install caca-utils -y
RUN apt-get install chafa -y
RUN apt-get install curl -y
RUN apt-get install wget -y
RUN apt-get install tshark -y
RUN apt-get install ktorrent -y
RUN apt-get install lshw -y
RUN apt-get install ranger -y
RUN apt-get install tree -y
RUN apt-get install mcrypt -y
RUN apt-get install vim vim-gtk3 nano -y
RUN apt-get install ncal -y
RUN apt-get install pbzip2 -y
RUN apt-get install tmux -y
RUN apt-get install xsensors -y
RUN apt-get install g++ gcc -y
RUN apt-get install python3 python3-pip python3-virtualenv -y
RUN apt-get install ruby ruby-dev -y
RUN apt-get install golang-go -y
RUN apt-get install default-jdk default-jre -y
RUN apt-get install neovim ripgrep python3-venv python3-pylsp clangd gopls -y
RUN gem install solargraph rubocop solar

RUN apt-get install python3-numpy -y
RUN apt-get install python3-pyqt5 -y
RUN apt-get install python3-matplotlib -y
RUN apt-get install python3-opencv -y
RUN apt-get install python3-flask -y
RUN apt-get install python3-colorama -y

COPY .vimrc /root/.vimrc
COPY .vim/ /root/.vim/
COPY .ssh/ /root/.ssh/
COPY .android/ /root/.android/

RUN git clone https://github.com/ian16munoz3nunez1/nvim.git ~/.config/nvim/
RUN git clone https://github.com/microsoft/java-debug.git ~/.local/share/java-debug
RUN cd ~/.local/share/java-debug && ./mvnw clean install

ENTRYPOINT tail -f /dev/null
