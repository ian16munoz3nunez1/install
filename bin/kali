#!/bin/bash

loading() {
    msg=$1

    echo -n "$msg"
    while true; do
        for i in {1..3}; do
            echo -n "."
            sleep 0.25
        done
        echo -ne "\b\b\b.  \b\b\b"
    done
}

new_passwd() {
    count=0
    while [ $count -lt 3 ]; do
        read -s -p "Enter a new password: " password
        password_0=$(echo $password | sha256sum | awk '{print $1}')
        echo

        read -s -p "Confirm your password: " password
        password_1=$(echo $password | sha256sum | awk '{print $1}')

        if [ "$password_0" = "$password_1" ]; then
            break
        else
            echo -e "\n\e[1;31mPasswords do not match!!\e[0m"
        fi

        count=$((count+1))
    done

    if [ $count -eq 3 ]; then
        echo -e "\n\e[1;31mNumber of attempts exceeded\e[0m"
        exit 2

    else
        echo -e "\n\e[1;32mPasswords match!!\e[0m"
        if [ ! -d /home/$USER/.config/kali ]; then
            mkdir -p /home/$USER/.config/kali
        fi

        echo "$password_0" > /home/$USER/.config/kali/passwd.dat
    fi
}

if [ $# -ne 1 ]; then
    echo "error: More or less arguments"
    echo "use: $0 <start/stop>"
    exit 1
fi

exists=$(docker ps -a | sed -r 's/\s{2,}/,/g' | cut -d, -f6 | grep -i kali &>/dev/null; echo $?)
if [ $exists -ne 0 ]; then
    echo "Docker kali does not exists"
fi

if [ $1 = start ]; then
    img=$(docker images | grep -i kali:latest &>/dev/null; echo $?)
    up=$(docker ps -a | grep -i kali | sed -r 's/\s{2,}/,/g' | cut -d, -f5 | grep -i up &>/dev/null; echo $?)

    if [ $img -eq 0 -a $up -ne 0 ]; then
        if [ ! -f $HOME/.config/kali/passwd.dat ]; then
            new_passwd
        fi

        loading "Running docker"&
        pid=$!
        docker run --name kali --privileged --net host -it \
            -e DISPLAY=$DISPLAY \
            -v /tmp/.X11-unix:/tmp/.X11-unix:ro \
            -v /etc/localtime:/etc/localtime:ro \
            --device /dev/dri \
            --device /dev/snd \
            -e PULSE_SERVER=unix:/run/user/1000/pulse/native \
            -v /run/user/1000/pulse:/run/user/1000/pulse:ro \
            -d kali
        kill $pid
        echo -ne "\r                  \r"
    fi

    up=$(docker ps -a | grep -i kali | sed -r 's/\s{2,}/,/g' | cut -d, -f5 | grep -i up &>/dev/null; echo $?)
    if [ $up -ne 0 ]; then
        loading "Starting docker"&
        pid=$!
        docker start kali &>/dev/null
        kill $pid
        echo -ne "\r                  \r"
    fi

    count=0
    while [ $count -lt 3 ]; do
        if [ -f $HOME/.config/kali/passwd.dat ]; then
            password_0=$(cat /home/$USER/.config/kali/passwd.dat)
            read -s -p "Insert password: " password
            password_1=$(echo $password | sha256sum | awk '{print $1}')

            if [ "$password_0" = "$password_1" ]; then
                break
            else
                echo -e "\e[1;31mPassword do not match!!\e[0m"
            fi
        else
            new_passwd
            exit 3
        fi

        count=$((count+1))
    done

    if [ $count -eq 3 ]; then
        echo -e "\n\e[1;31mNumber of attempts exceeded\e[0m"
        exit 4
    fi

    echo "Entering docker"
    docker exec -it kali /bin/bash
    exit 0
fi

if [ $1 = stop ]; then
    exited=$(docker ps -a | grep -i kali | sed -r 's/\s{2,}/,/g' | cut -d, -f5 | grep -i exited &>/dev/null; echo $?)

    if [ $exited -eq 0 ]; then
        echo "Docker already stopped"
    else
        loading "Stopping docker"&
        pid=$!
        docker stop kali &>/dev/null
        kill -9 $pid
        echo -ne "\r                  \r"
    fi

    exit 0
fi
